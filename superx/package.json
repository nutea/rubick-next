{
  "name": "rubick-superx-source",
  "private": true,
  "version": "2.0.12",
  "description": "可读源码：超级面板插件（Vue 3 + TypeScript），构建产物可同步到 public/superx",
  "scripts": {
    "dev:panel": "vite /main.html",
    "typecheck": "vue-tsc --noEmit",
    "build:web": "vite build",
    "build:node": "tsc -p tsconfig.node.json",
    "build": "npm run build:web && npm run build:node",
    "release": "node scripts/release.cjs"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^6.1.0",
    "ant-design-vue": "3.2.14",
    "vue": "^3.2.45"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "execa": "^5.1.1",
    "less": "^4.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.0.0",
    "vue-tsc": "^2.2.0"
  }
}
