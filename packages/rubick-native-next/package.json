{
  "name": "rubick-native-next",
  "version": "0.0.1",
  "private": true,
  "description": "In-repo native runtime package for Rubick Next, implemented from scratch.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/build-native.mjs --if-available",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint src --ext .ts",
    "native:check": "cargo check --manifest-path native/Cargo.toml",
    "native:build": "node ./scripts/build-native.mjs",
    "native:build:release": "node ./scripts/build-native.mjs --release"
  },
  "dependencies": {
    "@nut-tree/nut-js": "catalog:",
    "@types/node": "catalog:",
    "uiohook-napi": "^1.5.5",
    "typescript": "catalog:"
  },
  "optionalDependencies": {
    "electron-clipboard-ex": "^1.3.3"
  }
}
