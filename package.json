{
  "name": "rubick-next",
  "version": "4.3.8",
  "author": "nutea <nutgeek@gmail.com>",
  "private": true,
  "scripts": {
    "serve": "electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint src",
    "dev:all": "concurrently -n apps,electron \"pnpm run dev:apps\" \"electron-vite dev\"",
    "lint:apps": "pnpm --filter ./apps/** run lint",
    "dev:apps": "concurrently -n feature,detach,tpl,guide,sx-web,sx-node \"pnpm --filter feature run dev\" \"pnpm --filter detach run dev\" \"pnpm --filter tpl run dev\" \"pnpm --filter guide run dev\" \"pnpm --filter ./apps/superx run dev:web\" \"pnpm --filter ./apps/superx run dev:node\"",
    "apps:build": "pnpm --filter ./apps/** --parallel run build",
    "electron:serve": "electron-vite dev",
    "electron:build": "electron-vite build && electron-builder --config electron-builder.yml",
    "electron:build:local": "electron-vite build && electron-builder --config electron-builder.yml --publish never",
    "release": "electron-vite build && electron-builder --config electron-builder.yml",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps"
  },
  "main": "dist/main/entry.js",
  "optionalDependencies": {
    "electron-clipboard-ex": "^1.3.3"
  },
  "dependencies": {
    "@electron/remote": "catalog:",
    "@nut-tree/nut-js": "catalog:",
    "ant-design-vue": "catalog:",
    "axios": "catalog:",
    "compressing": "^1.10.4",
    "cross-spawn": "^7.0.6",
    "electron-updater": "^6.3.0",
    "extract-file-icon": "^0.3.2",
    "fix-path": "^3.0.0",
    "lodash.debounce": "catalog:",
    "memorystream": "^0.3.1",
    "node-key-sender": "^1.0.11",
    "pinyin-match": "^1.2.4",
    "pouchdb": "^7.2.2",
    "pouchdb-load": "^1.4.6",
    "pouchdb-replication-stream": "^1.2.9",
    "rubick-active-win": "^8.1.1",
    "semver": "^7.7.4",
    "simple-plist": "^0.2.1",
    "uiohook-napi": "^1.5.4",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "vuex": "catalog:",
    "webdav": "^4.11.3"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/compiler-sfc": "catalog:",
    "@vue/eslint-config-prettier": "catalog:",
    "@vue/eslint-config-typescript": "catalog:",
    "electron": "35.4.0",
    "electron-builder": "26.8.1",
    "concurrently": "^9.1.2",
    "electron-vite": "^2.3.0",
    "eslint": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "less": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:"
  },
  "resolutions": {
    "leveldown": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ejs",
      "electron",
      "electron-clipboard-ex",
      "electron-winstaller",
      "esbuild",
      "extract-file-icon",
      "leveldown",
      "rubick-active-win",
      "uiohook-napi"
    ]
  },
  "volta": {
    "node": "22.15.0"
  }
}
