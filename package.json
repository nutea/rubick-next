{
  "name": "rubick-next",
  "version": "5.0.0",
  "author": "nutea <nutgeek@gmail.com>",
  "private": true,
  "scripts": {
    "serve": "electron-vite dev",
    "packages:build": "pnpm --filter ./packages/** run build",
    "build": "pnpm packages:build && electron-vite build",
    "check:runtime-deps": "node scripts/check-runtime-deps.mjs",
    "lint": "eslint src",
    "dev:all": "concurrently -n apps,electron \"pnpm run dev:apps\" \"electron-vite dev\"",
    "lint:apps": "pnpm --filter ./apps/** run lint",
    "dev:apps": "concurrently -n feature,detach,tpl,guide,sx-web,sx-node \"pnpm --filter feature run dev\" \"pnpm --filter detach run dev\" \"pnpm --filter tpl run dev\" \"pnpm --filter guide run dev\" \"pnpm --filter ./apps/superx run dev:web\" \"pnpm --filter ./apps/superx run dev:node\"",
    "apps:build": "pnpm --filter ./apps/** --parallel run build",
    "electron:serve": "electron-vite dev",
    "electron:build": "pnpm packages:build && pnpm apps:build && electron-vite build && electron-builder --config electron-builder.yml --win nsis --x64",
    "electron:build:local": "pnpm packages:build && pnpm apps:build && electron-vite build && electron-builder --config electron-builder.yml --publish never --win nsis --x64",
    "release": "pnpm packages:build && pnpm apps:build && electron-vite build && electron-builder --config electron-builder.yml --win nsis --x64",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps"
  },
  "main": "dist/main/entry.js",
  "optionalDependencies": {
    "electron-clipboard-ex": "^1.3.3"
  },
  "dependencies": {
    "@ant-design/icons-vue": "catalog:",
    "@electron/remote": "catalog:",
    "ant-design-vue": "catalog:",
    "axios": "catalog:",
    "buffer-equal": "1.0.0",
    "compressing": "^1.10.4",
    "cross-spawn": "^7.0.6",
    "deferred-leveldown": "5.3.0",
    "delayed-stream": "1.0.0",
    "electron-updater": "^6.3.0",
    "event-target-shim": "5.0.1",
    "file-uri-to-path": "1.0.0",
    "fix-path": "^3.0.0",
    "fs-extra": "^10.1.0",
    "global": "4.4.0",
    "is-function": "1.0.2",
    "jsonfile": "6.2.0",
    "level-iterator-stream": "4.0.2",
    "lodash.debounce": "catalog:",
    "memorystream": "^0.3.1",
    "mime": "2.6.0",
    "mime-db": "1.52.0",
    "min-document": "2.19.0",
    "napi-macros": "2.0.0",
    "parse-bmfont-ascii": "1.0.6",
    "parse-bmfont-binary": "1.0.6",
    "parse-bmfont-xml": "1.1.6",
    "parse-headers": "2.0.6",
    "pinkie": "2.0.4",
    "pinyin-match": "^1.2.4",
    "plist": "^3.1.0",
    "pouchdb": "^7.2.2",
    "pouchdb-collections": "1.0.1",
    "pouchdb-load": "^1.4.6",
    "pouchdb-replication-stream": "^1.2.9",
    "querystringify": "2.2.0",
    "requires-port": "1.0.0",
    "rubick-native-next": "workspace:*",
    "semver": "^7.7.4",
    "simple-plist": "^0.2.1",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "vuex": "catalog:",
    "webdav": "^4.11.3",
    "xhr": "2.6.0",
    "xml-parse-from-string": "1.0.1",
    "xml2js": "0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/compiler-sfc": "catalog:",
    "@vue/eslint-config-prettier": "catalog:",
    "@vue/eslint-config-typescript": "catalog:",
    "concurrently": "^9.1.2",
    "electron": "35.4.0",
    "electron-builder": "26.8.1",
    "electron-vite": "^2.3.0",
    "eslint": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "less": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:"
  },
  "resolutions": {
    "leveldown": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ejs",
      "electron",
      "electron-clipboard-ex",
      "electron-winstaller",
      "esbuild",
      "leveldown",
      "uiohook-napi"
    ]
  },
  "volta": {
    "node": "22.15.0"
  }
}
